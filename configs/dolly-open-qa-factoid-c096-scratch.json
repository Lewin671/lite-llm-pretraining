{
  "run_name": "dolly-open-qa-factoid-c096-scratch",
  "seed": 42,
  "prepare": {
    "name": "dolly_qa",
    "source_url": "https://huggingface.co/datasets/databricks/databricks-dolly-15k/resolve/main/databricks-dolly-15k.jsonl",
    "train_split": 0.95,
    "split_seed": 42,
    "vocab_size": 2048,
    "model_type": "unigram",
    "byte_fallback": true,
    "input_sentence_size": 200000,
    "max_sentence_length": 16384,
    "tokenizer_model_path": "data/dolly-open-qa-short-u2048/tokenizer.model",
    "question_label": "Question",
    "context_label": "Context",
    "answer_label": "Answer",
    "instruction_text": "Answer with the exact fact in one to three words.",
    "context_word_limit": 0,
    "prompt_loss_weight": 0.0,
    "continuation_head_token_count": 8,
    "continuation_head_loss_weight": 3.0,
    "allowed_categories": ["open_qa"],
    "min_answer_words": 1,
    "max_answer_words": 12,
    "max_question_words": 24,
    "require_single_line_answer": true,
    "factoid_only": true,
    "normalize_factoid_answers": true,
    "max_normalized_answer_words": 3
  },
  "data_dir": "data/dolly-open-qa-factoid-u2048",
  "out_dir": "checkpoints/dolly-open-qa-factoid-c096-scratch",
  "sample_prompt": "What is the capital of Germany?",
  "sample_context": null,
  "suite_eval": {
    "suite_path": "prompts/dolly_open_qa_factoid_dev_v1.json",
    "temperature": 0.1,
    "top_k": 1,
    "max_new_tokens": 5,
    "eval_batches": 10,
    "seed": 123
  },
  "model": {
    "context_size": 96,
    "dim": 256,
    "num_layers": 4,
    "num_heads": 4,
    "gradient_checkpointing": true
  },
  "train": {
    "batch_size": 16,
    "max_steps": 500,
    "learning_rate": 0.0003,
    "weight_decay": 0.01,
    "warmup_steps": 20,
    "log_interval": 10,
    "eval_interval": 50,
    "eval_batches": 10,
    "checkpoint_interval": 50,
    "sample_interval": 50,
    "sample_tokens": 5,
    "sample_temperature": 0.1,
    "sample_top_k": 1,
    "batch_sampling_mode": "loss_window"
  }
}
