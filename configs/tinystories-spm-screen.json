{
  "run_name": "tinystories-spm-screen",
  "seed": 42,
  "prepare": {
    "name": "tinystories_sentencepiece",
    "byte_data_dir": "data/tinystories-byte-clean",
    "vocab_size": 2048,
    "model_type": "unigram",
    "input_sentence_size": 200000
  },
  "data_dir": "data/tinystories-spm-u2048",
  "out_dir": "checkpoints/tinystories-spm-screen",
  "sample_prompt": "Once upon a time,",
  "validation": {
    "prompts": [
      "Once upon a time,",
      "There was a little",
      "One day, a child named"
    ],
    "max_new_tokens": 120,
    "temperature": 0.7,
    "eval_batches": 10
  },
  "model": {
    "context_size": 256,
    "dim": 512,
    "num_layers": 10,
    "num_heads": 8,
    "gradient_checkpointing": true
  },
  "train": {
    "batch_size": 8,
    "max_steps": 300,
    "learning_rate": 0.00025,
    "weight_decay": 0.01,
    "warmup_steps": 300,
    "log_interval": 10,
    "eval_interval": 100,
    "eval_batches": 10,
    "checkpoint_interval": 300,
    "sample_interval": 300,
    "sample_tokens": 160,
    "sample_temperature": 0.7
  }
}
