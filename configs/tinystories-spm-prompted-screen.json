{
  "run_name": "tinystories-spm-prompted-screen",
  "seed": 42,
  "prepare": {
    "name": "tinystories_sentencepiece",
    "byte_data_dir": "data/tinystories-byte-clean",
    "vocab_size": 4096,
    "model_type": "unigram",
    "byte_fallback": true,
    "input_sentence_size": 200000,
    "max_sentence_length": 16384,
    "story_format": "prompt_continuation",
    "prompt_sentence_count": 1
  },
  "data_dir": "data/tinystories-spm-u4096-bf-pc1",
  "out_dir": "checkpoints/tinystories-spm-prompted-screen",
  "sample_prompt": "There was a little boy named Timmy who loved red kites.",
  "validation": {
    "prompts": [
      "There was a little boy named Timmy who loved red kites.",
      "Lily found a shiny key under the old tree.",
      "Maya and her puppy got lost in the big park."
    ],
    "max_new_tokens": 120,
    "temperature": 0.3,
    "eval_batches": 10
  },
  "model": {
    "context_size": 128,
    "dim": 512,
    "num_layers": 10,
    "num_heads": 8,
    "gradient_checkpointing": true
  },
  "train": {
    "batch_size": 8,
    "max_steps": 600,
    "learning_rate": 0.00025,
    "weight_decay": 0.01,
    "warmup_steps": 50,
    "log_interval": 10,
    "eval_interval": 150,
    "eval_batches": 10,
    "checkpoint_interval": 300,
    "sample_interval": 300,
    "sample_tokens": 160,
    "sample_temperature": 0.3
  }
}
